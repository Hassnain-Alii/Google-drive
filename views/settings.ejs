<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Settings - Google Drive</title>
    <link rel="icon" type="image/png" href="/images/drive-logo.png">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="stylesheet" href="/stylesheets/settings.css">
     <link
      rel="stylesheet"
      href="https://unpkg.com/tippy.js@6/animations/scale.css"
    />
    <link rel="stylesheet" href="/stylesheets/tippy.css" />
    <link rel="stylesheet" href="/stylesheets/dropdown.css" />
    <link rel="stylesheet" href="/stylesheets/partials/progressBar.css" />
    <link rel="stylesheet" href="/stylesheets/dropdown.css" />
    <link rel="stylesheet" href="/stylesheets/partials/loader.css" />
    <link rel="stylesheet" href="/stylesheets/partials/header.css" />


</head>
<body>
    <%- include('partials/header') %>
    
    <main class="settings-container">
        <div class="settings-sidebar">
            <h2>Settings</h2>
            <nav>
                <a href="#personal-info" class="active">Personal Info</a>
                <a href="#account-security">Security</a>
                <a href="#data-privacy">Data & Privacy</a>
            </nav>
        </div>

        <div class="settings-content">
            <section id="personal-info" class="settings-section">
                <h3>Personal Information</h3>
                <p>Information about you and your preferences across Google services</p>

                <% if (error && error.length > 0) { %>
                    <div class="alert alert-error"><%= error %></div>
                <% } %>
                <% if (success && success.length > 0) { %>
                    <div class="alert alert-success"><%= success %></div>
                <% } %>

                <form id="settings-form" action="/settings/update?_csrf=<%= csrfToken %>" method="POST" enctype="multipart/form-data">
                    <div class="settings-profile-img-section">
                        <div class="settings-profile-img-container">
                            <img id="settings-profile-preview" src="<%= user.profileImg ? '/settings/image/' + user._id + '?v=' + encodeURIComponent(user.profileImg) : '/images/Default-User.png' %>" alt="Profile Picture">
                            <div id="changePictureOverlay" class="settings-img-overlay">
                                <svg viewBox="0 0 24 24"><path d="M3 4V1h2v3h3v2H5v3H3V6H0V4h3zm3 6V7h3V4h7l1.83 2H21c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H5c-1.1 0-2-.9-2-2V10h3zm7 9c2.76 0 5-2.24 5-5s-2.24-5-5-5-5 2.24-5 5 2.24 5 5 5zm-3.2-5c0 1.77 1.43 3.2 3.2 3.2s3.2-1.43 3.2-3.2-1.43-3.2-3.2-3.2-3.2 1.43-3.2 3.2z"/></svg>
                            </div>
                            <input type="file" name="profileImg" id="profileImgInput" accept="image/*" hidden>
                        </div>
                        <button type="button" id="changePictureBtn" class="btn-text">Change Picture</button>
                    </div>

                    <div class="settings-info-form-grid">
                        <div class="settings-info-form-firstname-group settings-form-group">
                            <label for="firstname">First Name</label>
                            <input type="text" id="firstname" name="firstname" value="<%= user.firstname %>" >
                        </div>
                        <div class="settings-info-form-lastname-group settings-form-group">
                            <label for="lastname">Last Name</label>
                            <input type="text" id="lastname" name="lastname" value="<%= user.lastname %>">
                        </div>
                        <div class="settings-info-form-email-group settings-form-group full-width">
                            <label for="email">Email Address</label>
                            <input type="email" id="email" name="email" value="<%= user.email %>" >
                        </div>
                        <div class="settings-info-form-birthDate-group settings-form-group">
                            <label for="birthDate">Date of Birth</label>
                            <% 
                               let bDateStr = "";
                               if (user && user.birthDate) {
                                   const d = new Date(user.birthDate);
                                   if (!isNaN(d.getTime())) {
                                       bDateStr = d.toISOString().split('T')[0];
                                   }
                               }
                            %>
                            <input type="date" id="birthDate" name="birthDate" value="<%= bDateStr %>" >
                        </div>
                        <div class="settings-info-form-gender-group settings-form-group">
                            <label for="gender">Gender</label>
                            <select id="gender" name="gender" >
                                <option value="male" <%= user.gender === 'male' ? 'selected' : '' %>>Male</option>
                                <option value="female" <%= user.gender === 'female' ? 'selected' : '' %>>Female</option>
                                <option value="other" <%= user.gender === 'other' ? 'selected' : '' %>>Other</option>
                                <option value="prefer_not_to_say" <%= user.gender === 'prefer_not_to_say' ? 'selected' : '' %>>Prefer not to say</option>
                            </select>
                        </div>
                    </div>

                    <div class="settings-section-divider"></div>
                    <section id="account-security" class="settings-section">
                        <h3>Security</h3>
                        <div class="settings-form-password-grid">
                            <div class="settings-form-current-password-group settings-form-group">
                                <label for="currentPassword">Current Password</label>
                                <div class="password-input-wrapper">
                                    <input type="password" id="currentPassword" name="currentPassword" placeholder="Leave blank to keep current">
                                    <button type="button" class="toggle-password" data-target="currentPassword" aria-label="Toggle password visibility">
                                        <svg class="eye-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                    </button>
                                </div>
                                <span id="currentPasswordError" class="error"></span>
                            </div>
                            <div class="settings-form-new-password-grid">
                                <div class="settings-form-newPassword-group settings-form-group">
                                    <label for="newPassword">New Password</label>
                                    <div class="password-input-wrapper">
                                        <input type="password" id="newPassword" name="newPassword" placeholder="New Password">
                                        <button type="button" class="toggle-password" data-target="newPassword" aria-label="Toggle password visibility">
                                            <svg class="eye-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                        </button>
                                    </div>
                                    <span id="newPasswordError" class="error"></span>
                                </div>
                                <div class="settings-form-confirm-password-group settings-form-group">
                                    <label for="confirmPassword">Confirm Password</label>
                                    <div class="password-input-wrapper">
                                        <input type="password" id="confirmPassword" name="confirmPassword" placeholder="Confirm Password">
                                        <button type="button" class="toggle-password" data-target="confirmPassword" aria-label="Toggle password visibility">
                                            <svg class="eye-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                        </button>
                                    </div>
                                    <span id="confirmPasswordError" class="error"></span>
                                </div>
                            </div>
                        </div>

                        <div class="settings-form-actions">
                            <button type="submit" class="btn-primary">Save Changes</button>
                            <button type="reset" class="btn-secondary">Cancel</button>
                        </div>
                    </section>
                </form>
            </section>

        </div>
    </main>

    <script src="/javascripts/settings.js"></script>
    <script src="https://unpkg.com/@popperjs/core@2/dist/umd/popper.min.js"></script>
    <script src="https://unpkg.com/tippy.js@6"></script>
    <script src="/javascripts/tippy-init.js"></script>
    <script src="/javascripts/dropdown.js"></script>
    <script src="/javascripts/chevron.js"></script>
    <script src="/javascripts/fileIcons.js"></script>
    <script src="/javascripts/progressBar.js"></script>
</body> 
</html>
